<?xml version="1.0"?>

<!-- For more information on using Web.config transformation visit http://go.microsoft.com/fwlink/?LinkId=125889 -->

<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <connectionStrings>
        <add name="WireSecurity_Connection" 
             connectionString="" 
              xdt:Transform="Replace"
              xdt:Locator="Match(name)"/>
  </connectionStrings>
  <appSettings>
    <add key="FaxAppServerIP" value="10.128.252.190" xdt:Transform="Replace" xdt:Locator="Match(key)" />

    <add key="ApplicationId" value="50" xdt:Transform="Replace" xdt:Locator="Match(key)"  />

    <add key="EnvironmentId" value="25"  xdt:Transform="Replace" xdt:Locator="Match(key)"/>

    <add key="ReportDomain" value="+NIeFsBGo1SJ8YrnDjg5iOTjCLY1V1AkOkpA6WF2Tfc="  xdt:Transform="Replace" xdt:Locator="Match(key)" />

  </appSettings>
  <system.web>
    <compilation xdt:Transform="RemoveAttributes(debug)" />
  </system.web>

</configuration>