		<add key="ApplicationId" value="50" xdt:Transform="Replace" xdt:Locator="Match(key)"  />
		
		<add key="EnvironmentId" value="23"  xdt:Transform="Replace" xdt:Locator="Match(key)"/>
		
		<add key="ReportDomain" value="+NIeFsBGo1SJ8YrnDjg5iOTjCLY1V1AkOkpA6WF2Tfc="  xdt:Transform="Replace" xdt:Locator="Match(key)" />
		
  </appSettings>
  <system.web>
    <compilation xdt:Transform="RemoveAttributes(debug)" />
  </system.web>
  
</configuration>